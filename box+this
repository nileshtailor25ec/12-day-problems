#include <iostream>
using namespace std;
class Box {
    float length;
public:
    void setLength(float length) {
        this->length = length;
    }
    void display() { cout << "Length: " << length << endl; }
};
int main() {
    Box b;
    b.setLength(10.5);
    b.display();
    return 0;
}

Result-Length: 10.5
